# ── Python ──
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/

# ── Virtual environments ──
.venv/
venv/
env/

# ── PyInstaller build artifacts ──
# cs2xp.py's own "build" command already cleans these up automatically,
# but ignore them anyway in case a manual PyInstaller run is used instead.
build/
dist/
*.spec

# ── Compiled output ──
# Don't commit the compiled .exe to the repo itself — it should be attached
# to GitHub Releases instead (see README "Releases" section). Remove the
# line below if you specifically want to track the .exe in git.
*.exe

# ── Inno Setup build output ──
Output/
*.iss.bak

# ── User data ──
# This is the personal save file the script creates next to itself.
# Never commit a real one — it contains a specific person's XP progress.
cs2xp.json

# ── Editor / OS ──
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
