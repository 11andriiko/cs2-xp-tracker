# ── Python ──
# Ignore Python bytecode files, which are generated by the Python interpreter.
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/

# ── Virtual environments ──
# Ignore virtual environment directories, which may be created by various tools.
.venv/
venv/
env/

# ── PyInstaller build artifacts ──
# Ignore PyInstaller build artifacts, which may be generated by the PyInstaller tool.
build/
dist/
*.spec

# ── Compiled output ──
# Ignore compiled output files, which may be generated by various tools.
*.exe

# ── Inno Setup build output ──
# Ignore Inno Setup build output files, which may be generated by the Inno Setup tool.
Output/
*.iss
*.iss.bak

# ── User data ──
# Ignore user-specific configuration files, which may contain sensitive information.
*.json

# ── Editor / OS ──
# Ignore editor and operating system files, which may be generated by various tools.
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
